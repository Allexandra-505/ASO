#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_CALE    260
#define DIM_BUFFER  1024

int fnCitesteSiAfiseazaFisier(const char* pszCale)
{
    FILE* pfFisier = NULL;
    char  szBuffer[DIM_BUFFER];
    int   iResultat = 0;

    pfFisier = fopen(pszCale, "r");

    if (pfFisier == NULL)
    {
        fprintf(stderr, "Fisierul \"%s\" nu exista sau nu poate fi deschis.\n", pszCale);
        return -1;
    }

    while (fgets(szBuffer, DIM_BUFFER, pfFisier) != NULL)
    {
        printf("%s", szBuffer);
    }

    if (ferror(pfFisier))
    {
        fprintf(stderr, "A aparut o eroare la citirea fisierului.\n");
        iResultat = -1;
    }

    fclose(pfFisier);
    pfFisier = NULL;

    return iResultat;
}

void fnEliminarNewline(char* pszSir)
{
    size_t nLen = strlen(pszSir);

    if (nLen > 0 && pszSir[nLen - 1] == '\n')
        pszSir[--nLen] = '\0';

    if (nLen > 0 && pszSir[nLen - 1] == '\r')
        pszSir[--nLen] = '\0';
}

int main(void)
{
    char szCale[MAX_CALE];
    int  iCodRetur = 0;

    printf("Introduceti calea fisierului: ");

    if (fgets(szCale, MAX_CALE, stdin) == NULL)
    {
        fprintf(stderr, "Nu s-a putut citi calea fisierului.\n");
        return EXIT_FAILURE;
    }

    fnEliminarNewline(szCale);

    if (strlen(szCale) == 0)
    {
        fprintf(stderr, "Calea introdusa este vida.\n");
        return EXIT_FAILURE;
    }

    iCodRetur = fnCitesteSiAfiseazaFisier(szCale);

    if (iCodRetur == 0)
{
    return EXIT_SUCCESS;
}
else
{
    return EXIT_FAILURE;
}
}
